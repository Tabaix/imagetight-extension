{
  "manifest_version": 3,
  "name": "ImageTight Pro: Edge Inspector",
  "version": "2.0.0",
  "description": "Scan webpages for heavy images and SEO issues. Compress to WebP/AVIF instantly. Get your API key at imagetight.com/pricing.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ImageTight Pro Inspector",
    "default_icon": { "128": "icon.png" }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
